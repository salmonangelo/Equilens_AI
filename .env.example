# ============================================================
# EquiLens AI — Environment Configuration
# 
# Copy this file to .env and fill in your values
# 
# For LOCAL DEVELOPMENT: Set APP_ENV=local
# ============================================================

# --- Application ---
APP_NAME=EquiLens AI
APP_ENV=local              # local | development | staging | production
DEBUG=true
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR

# --- Server (Backend) ---
# For local development, these default values work fine.
# Use localhost:8080 to access the API
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080

# --- MCP Server (optional, for future use) ---
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# --- Google Cloud (required for Gemini explanations) ---
# For local testing without LLM explanations, leave GEMINI_API_KEY empty
# The system will gracefully fall back to deterministic responses
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# --- Gemini / Vertex AI ---
# Get your API key from: https://aistudio.google.com/apikey
# Optional for local testing (LLM explanations will be skipped)
GEMINI_API_KEY=your-gemini-api-key
VERTEX_AI_LOCATION=us-central1
MODEL_NAME=gemini-2.0-flash

# --- Database (future: PostgreSQL) ---
# Placeholder for future database integration
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/equilens

# --- CORS (Cross-Origin Resource Sharing) ---
# Allowed origins for frontend requests
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# --- Feature Flags ---
ENABLE_STREAMING=true
ENABLE_CACHING=false
